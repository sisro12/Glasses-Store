{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information including face analysis data.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile photo URL."
        },
        "faceShape": {
          "type": "string",
          "description": "The user's analyzed face shape."
        },
        "pd": {
          "type": "number",
          "description": "The user's pupillary distance."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "SavedTryOn": {
      "title": "SavedTryOn",
      "description": "A saved virtual try-on image.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this."
        },
        "itemId": {
          "type": "string",
          "description": "The ID of the item tried on."
        },
        "itemName": {
          "type": "string",
          "description": "The name of the item."
        },
        "category": {
          "type": "string",
          "description": "The category of the item."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The generated try-on image URL or base64 data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the try-on was saved."
        }
      },
      "required": ["userId", "itemId", "imageUrl", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the catalog.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "type": {
          "type": "string",
          "description": "The specific type/style of the product."
        },
        "category": {
          "type": "string",
          "description": "The category ID (e.g., glasses, watches)."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "stock": {
          "type": "number",
          "description": "The available stock quantity."
        },
        "image": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the product image."
        },
        "gender": {
          "type": "string",
          "enum": ["men", "women", "unisex"],
          "description": "The target gender for the product."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the product was created."
        }
      },
      "required": ["name", "type", "category", "price", "stock", "image", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the user who placed the order."
        },
        "items": {
          "type": "array",
          "description": "The items included in the order."
        },
        "totalAmount": {
          "type": "number",
          "description": "The total cost of the order."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"],
          "description": "The current status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was placed."
        }
      },
      "required": ["userId", "userEmail", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/tryons/{tryonId}": {
      "schema": { "$ref": "#/entities/SavedTryOn" },
      "description": "Stores saved virtual try-on images."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores products for the catalog."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores customer orders."
    }
  }
}
